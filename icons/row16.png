jQuery.event.add(window, "load", function(){
        $('#container').masonry({
            itemSelector: '.box',
            isAnimated: true,
            isFitWidth: true,
						columnWidth: 6,
						isResizable: true
        });
}); 
$(function($){
    $('.box').hide();
    $('.box').each(function (i) {
        $(this).delay(i * 100).fadeIn(1000);
    });
    $('ul#menu li').hide();
    $('ul#menu li').each(function (i) {
        $(this).delay(i * 200).fadeIn(2000);
    });
    $('#footer').hide();
    $('#footer').each(function (i) {
        $(this).delay(i * 500).fadeIn(4000);
    });
});
</script>
